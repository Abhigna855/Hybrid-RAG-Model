# Interactive query
def ask_question(query, top_k=5):
    print("\nUser Query:")
    print(query)

    retrieved_ids = hybrid_search(query, top_k)
    context = build_context(retrieved_ids)
    response = generate_answer(query, context)
    final_decision = extract_label(response)

    print("\nRetrieved Context (Top-K):")
    print(context[:500], "...")
    print("\nLLM Response:")
    print(response)
    print("\nFinal Decision:")
    print(final_decision.upper())

    return final_decision, response

