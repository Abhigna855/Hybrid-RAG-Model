# Parse context
def parse_context(context_val):
    try:
        if isinstance(context_val, dict):
            context_json = context_val
        else:
            context_json = ast.literal_eval(str(context_val))

        context_list = context_json.get("contexts", [])
        labels = context_json.get("labels", [])
        meshes = context_json.get("meshes", [])
        full_text = " ".join(context_list)

        return pd.Series([context_list, labels, meshes, full_text])
    except Exception:
        return pd.Series([[], [], [], ""])

df[["context_list", "labels", "meshes", "context_text"]] = df["context"].apply(parse_context)

# Clean text
def clean_text(text):
    text = re.sub(r"\n+", " ", str(text))
    text = re.sub(r"[^a-zA-Z0-9\s]", " ", text)
    text = re.sub(r"\s+", " ", text)
    return text.lower().strip()

df["clean_context"] = df["context_text"].apply(clean_text)
df["clean_question"] = df["question"].apply(clean_text)

documents = df["clean_context"].tolist()
tokenized_corpus = [doc.split() for doc in documents]

# Split data
train_data, test_data = train_test_split(
    df, test_size=0.2, random_state=42, stratify=df["final_decision"]
)

# Embeddings and indexes
embed_model = SentenceTransformer("all-MiniLM-L6-v2")
embeddings = embed_model.encode(documents, show_progress_bar=True).astype("float32")
faiss.normalize_L2(embeddings)

index = faiss.IndexFlatIP(embeddings.shape[1])
index.add(embeddings)

bm25 = BM25Okapi(tokenized_corpus)

# Retrieval functions
def dense_search(query, top_k=5):
    query_emb = embed_model.encode([query]).astype("float32")
    faiss.normalize_L2(query_emb)
    scores, indices = index.search(query_emb, top_k)
    return indices[0].tolist()

def bm25_search(query, top_k=5):
    scores = bm25.get_scores(query.split())
    return np.argsort(scores)[::-1][:top_k].tolist()

def reciprocal_rank_fusion(bm25_ids, dense_ids, k=60):
    scores = {}
    for rank, doc_id in enumerate(bm25_ids):
        scores[doc_id] = scores.get(doc_id, 0) + 1 / (k + rank + 1)
    for rank, doc_id in enumerate(dense_ids):
        scores[doc_id] = scores.get(doc_id, 0) + 1 / (k + rank + 1)

    ranked = sorted(scores.items(), key=lambda x: x[1], reverse=True)
    return [doc_id for doc_id, _ in ranked]

def hybrid_search(query, top_k=5):
    cleaned_query = clean_text(query)
    dense_ids = dense_search(cleaned_query, top_k * 2)
    bm25_ids = bm25_search(cleaned_query, top_k * 2)
    fused_ids = reciprocal_rank_fusion(bm25_ids, dense_ids)
    return fused_ids[:top_k]

def build_context(doc_ids):
    return "\n".join([documents[i] for i in doc_ids])

# Load generation model
t5_tokenizer = T5Tokenizer.from_pretrained("google/flan-t5-base")
t5_model = T5ForConditionalGeneration.from_pretrained("google/flan-t5-base")

def generate_answer(query, context):
    prompt = f"""Answer the question with yes, no, or maybe.

Context:
{context}

Question:
{query}

Answer:"""
    inputs = t5_tokenizer(prompt, return_tensors="pt", truncation=True, max_length=512)
    outputs = t5_model.generate(**inputs, max_new_tokens=20)
    response = t5_tokenizer.decode(outputs[0], skip_special_tokens=True)
    return response.strip()

# Systems
def baseline_system(query):
    return generate_answer(query, "")

def dense_rag(query):
    ids = dense_search(clean_text(query))
    context = build_context(ids)
    return generate_answer(query, context)

def hybrid_rag(query):
    ids = hybrid_search(query)
    context = build_context(ids)
    return generate_answer(query, context)

# Label extraction
def extract_label(text):
    text = str(text).lower().strip()
    if "yes" in text:
        return "yes"
    elif "no" in text:
        return "no"
    else:
        return "maybe"

# System evaluation
def evaluate_system(system_func, data_sample):
    results = []

    for _, row in data_sample.iterrows():
        query = row["clean_question"]
        true_label = str(row["final_decision"]).lower().strip()

        start = time.time()
        response = system_func(query)
        pred_label = extract_label(response)
        latency = time.time() - start

        results.append({
            "correct": pred_label == true_label,
            "latency": latency
        })

    return pd.DataFrame(results)

# Compare systems
sample_data = test_data.sample(min(50, len(test_data)), random_state=42)

baseline_results = evaluate_system(baseline_system, sample_data)
dense_results = evaluate_system(dense_rag, sample_data)
hybrid_results = evaluate_system(hybrid_rag, sample_data)

def compute_metrics(result_df):
    accuracy = result_df["correct"].mean()
    latency = result_df["latency"].mean()
    return accuracy, latency

baseline_acc, baseline_lat = compute_metrics(baseline_results)
dense_acc, dense_lat = compute_metrics(dense_results)
hybrid_acc, hybrid_lat = compute_metrics(hybrid_results)

