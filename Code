# Retrieval and generation metrics
def precision_at_k(retrieved_ids, relevant_ids, k):
    retrieved_k = retrieved_ids[:k]
    if k == 0:
        return 0
    return len(set(retrieved_k) & set(relevant_ids)) / k

def recall_at_k(retrieved_ids, relevant_ids, k):
    retrieved_k = retrieved_ids[:k]
    if len(relevant_ids) == 0:
        return 0
    return len(set(retrieved_k) & set(relevant_ids)) / len(relevant_ids)

def mean_reciprocal_rank(retrieved_ids, relevant_ids):
    for rank, doc_id in enumerate(retrieved_ids, start=1):
        if doc_id in relevant_ids:
            return 1 / rank
    return 0

def dcg(retrieved_ids, relevant_ids, k):
    score = 0
    for i, doc_id in enumerate(retrieved_ids[:k]):
        if doc_id in relevant_ids:
            score += 1 / math.log2(i + 2)
    return score

def ndcg(retrieved_ids, relevant_ids, k):
    ideal = dcg(relevant_ids, relevant_ids, k)
    if ideal == 0:
        return 0
    return dcg(retrieved_ids, relevant_ids, k) / ideal

def exact_match(pred, truth):
    return int(str(pred).strip().lower() == str(truth).strip().lower())

def f1_score_fn(pred, truth):
    pred_tokens = str(pred).split()
    truth_tokens = str(truth).split()
    common = Counter(pred_tokens) & Counter(truth_tokens)
    num_same = sum(common.values())

    if num_same == 0:
        return 0

    precision = num_same / len(pred_tokens)
    recall = num_same / len(truth_tokens)
    return 2 * precision * recall / (precision + recall)

def bleu_score_fn(pred, truth):
    smoothie = SmoothingFunction().method1
    return sentence_bleu([str(truth).split()], str(pred).split(), smoothing_function=smoothie)

def rouge_score_fn(pred, truth):
    scorer = rouge_scorer.RougeScorer(["rouge1", "rougeL"], use_stemmer=True)
    return scorer.score(str(truth), str(pred))

# Full evaluation
results = []

for _, row in test_data.head(50).iterrows():
    query = row["clean_question"]
    true_answer = str(row["final_decision"]).lower().strip()

    dense_ids = dense_search(query, top_k=5)
    bm25_ids = bm25_search(query, top_k=5)
    hybrid_ids = reciprocal_rank_fusion(bm25_ids, dense_ids)

    relevant_ids = [row.name]

    p = precision_at_k(hybrid_ids, relevant_ids, 5)
    r = recall_at_k(hybrid_ids, relevant_ids, 5)
    mrr = mean_reciprocal_rank(hybrid_ids, relevant_ids)
    nd = ndcg(hybrid_ids, relevant_ids, 5)

    context = build_context(hybrid_ids[:5])
    pred_answer = extract_label(generate_answer(query, context))

    em = exact_match(pred_answer, true_answer)
    f1 = f1_score_fn(pred_answer, true_answer)
    bleu = bleu_score_fn(pred_answer, true_answer)
    rouge = rouge_score_fn(pred_answer, true_answer)

    start_time = time.time()
    _ = generate_answer(query, context)
    latency = time.time() - start_time

    results.append({
        "precision": p,
        "recall": r,
        "mrr": mrr,
        "ndcg": nd,
        "em": em,
        "f1": f1,
        "bleu": bleu,
        "rouge1": rouge["rouge1"].fmeasure,
        "rougeL": rouge["rougeL"].fmeasure,
        "latency": latency
    })

results_df = pd.DataFrame(results)
print(results_df.mean(numeric_only=True))

